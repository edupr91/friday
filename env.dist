# friday configuration — copy to `.env` and fill in your values.
#   cp env.dist .env
# All values except GEMINI_API_KEY are optional; defaults are shown.

# --- Required ----------------------------------------------------------------
# Your Google Generative Language (Gemini) API key.
GEMINI_API_KEY=

# --- Models ------------------------------------------------------------------
# Primary model. Default is the stable 2.5-flash: with thinking off it answers
# in ~1-2s and isn't capacity-constrained like the "-preview" models.
GEMINI_MODEL=gemini-2.5-flash

# Fallback model, used on repeated 5xx/429 ("high demand") errors.
GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite

# --- Behaviour ---------------------------------------------------------------
# Thinking mode: off | low | high. "off" is fastest (~15x). gemini-3 models
# treat "off"/"low" the same (they can't fully disable thinking).
GEMINI_THINKING=off

# Max tokens in the generated answer.
GEMINI_MAX_TOKENS=2048

# Retries (with exponential backoff) on transient 429/503 before giving up.
GEMINI_MAX_RETRIES=3
